{
  "productName": "auto-cpufreq",
  "version": "1.0.0",
  "identifier": "com.autocpufreq.rust",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "auto-cpufreq",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "scripts/auto-cpufreq-rust.service"
    ],
    "deb": {
      "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"],
      "files": {
        "/usr/lib/systemd/system/auto-cpufreq-rust.service": "scripts/auto-cpufreq-rust.service"
      }
    }
  }
}
